rules_version = '2';

// Forge — Firestore security rules.
// NOTE: GitHub Pages does not deploy this file. Paste it into the Firebase
// console (project forge-bc1d3 → Firestore Database → Rules) or deploy with the
// Firebase CLI. This file is the version-controlled source of truth.
//
// Firebase Authentication has been removed — identity is local (localStorage)
// and access is gated by the in-app invite code. Rules therefore cannot use
// request.auth, so reads/writes are open. Acceptable for a small, private,
// trusted group behind the invite-code gate.

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
